# ---------------------------------------------------------------------------
# Supabase — user-facing and currently the source of truth for auth
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The app works in demo mode without these — just leave them as-is to test locally.

# ---------------------------------------------------------------------------
# Better Auth — infrastructure only in session 1. See BETTER-AUTH-MIGRATION.md
# ---------------------------------------------------------------------------
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
BETTER_AUTH_SECRET=replace-with-48-byte-random-string

# Canonical URL where the auth endpoints are hosted. Dev is http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173

# Direct Postgres connection to Supabase. From Supabase dashboard →
# Settings → Database → Connection string → "Session pooler".
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ---------------------------------------------------------------------------
# /api/leads endpoint — server-only secrets, set these in Vercel only.
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# LEADS_ALLOWED_ORIGINS=https://vekstor.no,https://www.vekstor.no
